{
  "name": "ActivationCode",
  "type": "object",
  "properties": {
    "code": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "billing": {
      "type": "string",
      "enum": [
        "monthly",
        "yearly"
      ]
    },
    "used": {
      "type": "boolean"
    },
    "used_by": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    }
  },
  "required": [
    "code",
    "plan_id",
    "billing"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}