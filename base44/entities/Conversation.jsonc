{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "conv_id": {
      "type": "string",
      "title": "Conversation ID"
    },
    "title": {
      "type": "string",
      "title": "Title"
    },
    "raw_content": {
      "type": "string",
      "title": "Generated Code",
      "format": "textarea"
    },
    "raw_content_url": {
      "type": "string",
      "title": "Content File URL"
    },
    "thumbnail_url": {
      "type": "string",
      "title": "Thumbnail Image URL"
    },
    "is_public": {
      "type": "boolean",
      "title": "Is Public",
      "default": false
    },
    "messages_json": {
      "type": "string",
      "title": "Messages",
      "format": "textarea"
    }
  },
  "required": [
    "conv_id"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "data.is_public": true
        },
        {
          "created_by_id": "{{user.id}}"
        }
      ]
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}