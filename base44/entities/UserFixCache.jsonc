{
  "name": "UserFixCache",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "title": "User ID"
    },
    "issue_key": {
      "type": "string",
      "title": "Issue key (normalized)"
    },
    "site_url": {
      "type": "string",
      "title": "Site URL"
    },
    "summary": {
      "type": "string",
      "title": "Summary",
      "maxLength": 2000
    },
    "steps": {
      "type": "string",
      "title": "Steps JSON",
      "format": "textarea"
    },
    "prompt": {
      "type": "string",
      "title": "Prompt (for ai_nocode profile)",
      "format": "textarea"
    },
    "explanation": {
      "type": "string",
      "title": "Explanation (for developer profile)",
      "format": "textarea"
    },
    "time_estimate": {
      "type": "string",
      "title": "Time estimate"
    },
    "fix_type": {
      "type": "string",
      "title": "Type (autonome/developpeur)"
    },
    "profile_type": {
      "type": "string",
      "title": "Profile type (no_code/ai_nocode/developer)"
    }
  },
  "required": [
    "user_id",
    "issue_key"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}