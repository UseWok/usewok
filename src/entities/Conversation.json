{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "conv_id": {
      "type": "string",
      "description": "Unique conversation identifier"
    },
    "title": {
      "type": "string",
      "description": "Discussion title"
    },
    "preview": {
      "type": "string",
      "description": "Short preview/description of the conversation"
    },
    "messages_json": {
      "type": "string",
      "format": "textarea",
      "description": "Serialized messages array (JSON)"
    },
    "raw_content": {
      "type": "string",
      "format": "textarea",
      "description": "Generated React component code"
    },
    "model": {
      "type": "string",
      "description": "AI model used for generation"
    },
    "agent": {
      "type": "string",
      "description": "Agent name/ID"
    },
    "is_public": {
      "type": "boolean",
      "default": false,
      "description": "Whether the conversation is publicly accessible"
    },
    "slug": {
      "type": "string",
      "description": "Custom URL slug for sharing"
    }
  },
  "required": ["conv_id"],
  "rls": {
    "create": true,
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "is_public": true
        }
      ]
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}