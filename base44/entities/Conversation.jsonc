{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "Titre"
    },
    "site_url": {
      "type": "string",
      "title": "Site URL"
    },
    "messages_json": {
      "type": "string",
      "title": "Messages (JSON)",
      "format": "textarea"
    },
    "updated_at": {
      "type": "number",
      "title": "Updated At (timestamp)"
    }
  },
  "required": [],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}