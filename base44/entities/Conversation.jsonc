{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "conv_id": {
      "type": "string",
      "title": "Conversation ID"
    },
    "title": {
      "type": "string",
      "title": "Title"
    },
    "preview": {
      "type": "string",
      "title": "Preview"
    },
    "model": {
      "type": "string",
      "title": "Model"
    },
    "agent": {
      "type": "string",
      "title": "Agent"
    },
    "is_public": {
      "type": "boolean",
      "title": "Is Public"
    },
    "messages_json": {
      "type": "string",
      "title": "Messages JSON",
      "format": "textarea"
    },
    "raw_content": {
      "type": "string",
      "title": "Generated UI Code",
      "format": "textarea"
    },
    "description": {
      "type": "string",
      "title": "Description / Raw Content (legacy)",
      "maxLength": 1000
    }
  },
  "required": [
    "conv_id"
  ],
  "rls": {
    "create": true,
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "data.is_public": true
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}