{
  "name": "Testimonial",
  "type": "object",
  "properties": {
    "author_name": {
      "type": "string",
      "title": "Nom"
    },
    "author_role": {
      "type": "string",
      "title": "R\u00f4le / Entreprise"
    },
    "rating": {
      "type": "number",
      "title": "Note (1-5)",
      "default": 5
    },
    "text": {
      "type": "string",
      "title": "Avis",
      "format": "textarea"
    },
    "avatar_url": {
      "type": "string",
      "title": "Photo (URL)"
    },
    "avatar_color": {
      "type": "string",
      "title": "Couleur avatar",
      "default": "sunset",
      "description": "sunset, violet, ocean, mint, ink"
    },
    "verified": {
      "type": "boolean",
      "title": "Certifi\u00e9",
      "default": false
    },
    "visible": {
      "type": "boolean",
      "title": "Visible sur le site",
      "default": true
    },
    "order": {
      "type": "number",
      "title": "Ordre d'affichage",
      "default": 0
    }
  },
  "required": [
    "author_name",
    "text"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}